{
  "name": "youtube-mcp",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "dev": "tsc && node dist/index.js",
    "dev:http": "tsc && node dist/index.js --http"
  },
  "keywords": [
    "mcp",
    "youtube",
    "transcript"
  ],
  "author": "",
  "license": "ISC",
