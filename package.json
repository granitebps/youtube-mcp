    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "youtube-transcript-plus": "^2.0.0",
    "youtubei.js": "^17.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
