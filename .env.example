# No API key required! All YouTube data is fetched via youtubei.js (InnerTube API).
# The following are optional configuration for HTTP/VPS deployment:
# TRANSPORT=http
# PORT=3000
# HOST=0.0.0.0

# Optional: Set a secret token to protect your HTTP endpoint.
# If set, all requests must include: Authorization: Bearer <your-token>
# Leave unset for local development (no auth required).
# API_TOKEN=your-secret-token-here
